# Mapbox access token (public token, pk.xxx) - https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here

# Webhook endpoint waar e-mail/WhatsApp payloads naartoe gestuurd worden
WEBHOOK_URL=https://apihier.com/api/webhook

# Vercel KV (wordt automatisch gezet als je een KV store koppelt in Vercel)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Wachtwoord voor de beheerpagina's (alles behalve /boeken)
ADMIN_PASSWORD=
